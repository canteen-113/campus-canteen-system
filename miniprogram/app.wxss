page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f8fafc;
  font-size: 28rpx;
  color: #1e293b;
}

/* 通用容器 */
.container { padding: 24rpx; }
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

/* 文字 */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }
.text-center { text-align: center; }
.font-bold { font-weight: 700; }
.font-black { font-weight: 900; }
.text-slate-400 { color: #94a3b8; }
.text-slate-500 { color: #64748b; }
.text-slate-600 { color: #475569; }
.text-slate-800 { color: #1e293b; }
.text-blue-600 { color: #2563eb; }
.text-white { color: #ffffff; }
.text-emerald-600 { color: #059669; }
.text-amber-500 { color: #f59e0b; }
.text-red-400 { color: #f87171; }
.text-orange-500 { color: #f97316; }

/* 背景 */
.bg-white { background-color: #ffffff; }
.bg-slate-50 { background-color: #f8fafc; }
.bg-blue-50 { background-color: #eff6ff; }
.bg-blue-600 { background-color: #2563eb; }
.bg-slate-900 { background-color: #0f172a; }
.bg-emerald-50 { background-color: #ecfdf5; }
.bg-amber-50 { background-color: #fffbeb; }
.bg-orange-50 { background-color: #fff7ed; }

/* 圆角 */
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 20rpx; }
.rounded-2xl { border-radius: 32rpx; }
.rounded-3xl { border-radius: 40rpx; }
.rounded-full { border-radius: 9999rpx; }

/* 阴影 */
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.shadow { box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); }
.shadow-lg { box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12); }

/* 间距 */
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-6 { margin-top: 48rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }
.ml-1 { margin-left: 8rpx; }
.mr-2 { margin-right: 16rpx; }
.p-2 { padding: 16rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }
.p-6 { padding: 48rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.px-6 { padding-left: 48rpx; padding-right: 48rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }

/* 按钮 */
.btn-primary {
  background-color: #2563eb;
  color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  font-weight: 700;
  font-size: 28rpx;
}
.btn-primary:active { background-color: #1d4ed8; transform: scale(0.98); }

.btn-outline {
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #475569;
  background: #ffffff;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 输入框 */
.input-field {
  width: 100%;
  padding: 24rpx 32rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: #e2e8f0;
  margin: 32rpx 0;
}

/* 隐藏滚动条 */
.hide-scrollbar::-webkit-scrollbar { display: none; }
