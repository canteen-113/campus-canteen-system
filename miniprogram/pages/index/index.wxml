<view class="page-index">
  <!-- 头部背景 -->
  <view class="header-bg">
    <view class="header-top">
      <view>
        <text class="greeting-text">欢迎回来，</text>
        <view class="flex-row">
          <text class="user-name">{{userName}}同学</text>
        </view>
      </view>
      <view class="flex-row" style="gap:24rpx;">
        <view class="bell-icon">
          <text>🔔</text>
          <view class="badge"></view>
        </view>
      </view>
    </view>

    <!-- 余额卡片 -->
    <view class="balance-card">
      <view class="flex-row">
        <view class="balance-icon">
          <text>💳</text>
        </view>
        <view class="flex-1">
          <text class="card-label">一卡通余额</text>
          <text class="card-amount">¥ {{balance}}</text>
        </view>
      </view>
      <button class="recharge-btn" bindtap="quickRecharge">快捷充值</button>
    </view>
  </view>

  <!-- 滚动内容区 -->
  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 待取餐提醒 -->
    <view class="section" wx:if="{{pendingOrder}}">
      <view class="flex-between mb-4">
        <text class="section-title">当前任务</text>
        <text class="text-xs text-blue-600">查看详情</text>
      </view>
      <navigator url="/pages/collect/collect" class="pending-card">
        <view class="flex-between">
          <view>
            <text class="pending-title">待取餐：{{pendingOrder.mealPeriod}}时段</text>
            <view class="mt-1">
              <text class="pending-code">取餐码：</text>
              <text class="pending-code-value">#{{pendingOrder.pickupCode}}</text>
            </view>
          </view>
          <text>➡️</text>
        </view>
      </navigator>
    </view>

    <!-- 快捷菜单 -->
    <view class="grid-4">
      <navigator url="/pages/menu/menu" class="grid-item">
        <view class="grid-icon grid-icon-blue">
          <text>🍽️</text>
        </view>
        <text class="grid-label">菜品浏览</text>
      </navigator>
      <navigator url="/pages/reserve/reserve" class="grid-item">
        <view class="grid-icon grid-icon-green">
          <text>📅</text>
        </view>
        <text class="grid-label">点餐预约</text>
      </navigator>
      <navigator url="/pages/comment/comment" class="grid-item">
        <view class="grid-icon grid-icon-amber">
          <text>⭐</text>
        </view>
        <text class="grid-label">评价反馈</text>
      </navigator>
      <navigator url="/pages/bills/bills" class="grid-item">
        <view class="grid-icon grid-icon-indigo">
          <text>📄</text>
        </view>
        <text class="grid-label">我的账单</text>
      </navigator>
    </view>

    <!-- 今日推荐 -->
    <view class="section">
      <text class="section-title mb-4">今日特色推荐</text>
      <view class="dish-list">
        <view class="dish-card" wx:for="{{recommendList}}" wx:key="id">
          <image class="dish-img" src="{{item.image}}" mode="aspectFill"/>
          <view class="flex-1 dish-info">
            <text class="dish-name">{{item.name}}</text>
            <view class="flex-row" style="gap:8rpx; margin-top:8rpx;">
              <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
            </view>
            <view class="flex-between dish-bottom">
              <text class="dish-price">¥ {{item.price}}</text>
              <text class="text-xs text-slate-400">{{item.canteenName}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 公告栏 -->
    <view class="announce-card" wx:if="{{announcements.length > 0}}">
      <view class="flex-row mb-2">
        <text>📢</text>
        <text class="text-xs font-bold" style="color:#1e40af; margin-left:8rpx;">食堂公告</text>
      </view>
      <text class="announce-text" wx:for="{{announcements}}" wx:key="id">{{item.content || item.title}}</text>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
