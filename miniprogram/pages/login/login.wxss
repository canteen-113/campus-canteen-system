.page-login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 48rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(37, 99, 235, 0.3);
}

.logo-icon {
  font-size: 72rpx;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
}

.login-form {
  width: 100%;
  max-width: 600rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 12rpx;
  margin-left: 8rpx;
}

.input-field {
  width: 100%;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-extra {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
  margin-bottom: 40rpx;
}

.remember-label {
  display: flex;
  align-items: center;
}

.remember-label checkbox {
  margin-right: 8rpx;
}

.btn-primary {
  background-color: #2563eb;
  color: #fff;
  border: none;
}

.login-btn {
  width: 100%;
  padding: 32rpx;
  font-size: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.25);
}

.login-footer {
  margin-top: 120rpx;
  text-align: center;
}

.text-xs {
  font-size: 24rpx;
}

.text-slate-500 {
  color: #64748b;
}

.text-slate-400 {
  color: #94a3b8;
}