<view class="page-menu">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索菜品名称、餐厅..." value="{{keyword}}" bindinput="onSearchInput"/>
    </view>
  </view>

  <!-- 内容区：左侧分类 + 右侧列表 -->
  <view class="menu-body">
    <scroll-view class="category-sidebar" scroll-y>
      <view class="cat-item {{activeCategory === '' ? 'cat-active' : ''}}" bindtap="switchCategory" data-id="">
        <text class="cat-text {{activeCategory === '' ? 'cat-text-active' : ''}}">全部</text>
      </view>
      <view class="cat-item {{activeCategory === item.id ? 'cat-active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{item.id}}">
        <text class="cat-text {{activeCategory === item.id ? 'cat-text-active' : ''}}">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="dish-content" scroll-y>
      <view class="dish-card" wx:for="{{dishes}}" wx:key="id">
        <image class="dish-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.canteenName}} · {{item.weight || ''}} · {{item.calories || ''}}kcal</text>
          <view class="flex-row" style="gap:8rpx; margin-top:8rpx;">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="flex-between dish-bottom">
            <view>
              <text class="dish-price">¥ {{item.price}}</text>
              <text class="stock-warn" wx:if="{{item.stock <= 20 && item.stock > 0}}">仅剩 {{item.stock}} 份</text>
            </view>
            <button class="add-btn" wx:if="{{item.stock > 0}}" bindtap="addToCart" data-item="{{item}}">+</button>
            <text class="sold-out" wx:else>已售罄</text>
          </view>
        </view>
      </view>
      <view wx:if="{{dishes.length === 0}}" class="empty-text">暂无菜品</view>
      <view style="height:40rpx;"></view>
    </scroll-view>
  </view>

  <!-- 悬浮购物车按钮 -->
  <view class="cart-float" bindtap="goReserve">
    <view class="cart-icon-box">
      <text class="cart-icon">🛒</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">
        <text class="cart-badge-text">{{cartCount}}</text>
      </view>
    </view>
  </view>
</view>
