<view class="page-order">
  <!-- 顶部标题栏 -->
  <view class="top-bar">
    <text class="top-title">我的订单</text>
  </view>

  <!-- 标签切换 -->
  <view class="tabs">
    <view class="tab {{activeTab===''?'tab-on':''}}" bindtap="onTab" data-tab="">全部</view>
    <view class="tab {{activeTab==='待取餐'?'tab-on':''}}" bindtap="onTab" data-tab="待取餐">待取餐</view>
    <view class="tab {{activeTab==='已完成'?'tab-on':''}}" bindtap="onTab" data-tab="已完成">已完成</view>
    <view class="tab {{activeTab==='已取消'?'tab-on':''}}" bindtap="onTab" data-tab="已取消">已取消</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="card {{item.status==='已完成'?'card-done':''}}" wx:for="{{list}}" wx:key="id">
      <!-- 头部：食堂信息 + 状态 -->
      <view class="card-hd">
        <view class="flex-row">
          <view class="canteen-icon">
            <text>🍴</text>
          </view>
          <text class="canteen-name">{{item.canteenName}} · {{item.windowName}}</text>
        </view>
        <text class="stag" style="color:{{item.stColor}};background:{{item.stBg}}">{{item.status}}</text>
      </view>

      <!-- 主体：图片 + 信息 -->
      <view class="card-body">
        <image class="dish-img" src="{{item.firstImage}}" mode="aspectFill"/>
        <view class="dish-info">
          <text class="dish-name">{{item.firstDishName}}</text>
          <text class="dish-meta">下单时间：{{item.createTime}}</text>
          <text class="dish-meta" wx:if="{{item.mealPeriod}}">就餐时段：{{item.mealPeriod}}</text>
          <view class="dish-bottom">
            <text class="dish-price">¥{{item.totalPrice}}</text>
            <text class="dish-qty">共 {{item.totalQty}} 件</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="card-btns" wx:if="{{item.status==='待取餐'||item.status==='已完成'}}">
        <button class="btn btn-outline" wx:if="{{item.status==='待取餐'}}" bindtap="onCancel" data-id="{{item.id}}">取消预约</button>
        <navigator url="/pages/collect/collect?code={{item.pickupCode}}" wx:if="{{item.status==='待取餐'}}" class="btn btn-primary">展示取餐码</navigator>
        <navigator url="/pages/comment/comment?orderId={{item.id}}" wx:if="{{item.status==='已完成'}}" class="btn btn-gray">去评价</navigator>
        <button class="btn btn-outline" wx:if="{{item.status==='已完成'}}" bindtap="onAgain" data-id="{{item.id}}">再来一份</button>
      </view>
    </view>

    <view wx:if="{{list.length===0}}" class="empty-text">暂无订单</view>
    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
