/* 订单页 - 与首页/菜单页统一风格 */
.page-order {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8fafc;
}

/* 顶部标题栏 */
.top-bar {
  background: #ffffff;
  padding: 24rpx 48rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

/* 标签 */
.tabs {
  display: flex;
  background: #ffffff;
  padding: 16rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #94a3b8;
}

.tab-on {
  color: #2563eb;
  font-weight: 700;
  border-bottom: 4rpx solid #2563eb;
}

/* 滚动列表 */
.list {
  flex: 1;
  padding: 24rpx 24rpx 0;
}

/* 订单卡片 - 统一 dish-card 风格 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f1f5f9;
  margin-bottom: 24rpx;
}

.card-done {
  opacity: 0.85;
}

/* 卡片头部 */
.card-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.canteen-icon {
  width: 40rpx;
  height: 40rpx;
  background: #eff6ff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 22rpx;
}

.canteen-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1e293b;
}

.stag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

/* 卡片主体 */
.card-body {
  display: flex;
  flex-direction: row;
}

.dish-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.dish-meta {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.dish-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
}

.dish-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563eb;
}

.dish-qty {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 按钮区 */
.card-btns {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.btn {
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 16rpx;
}

.btn-primary {
  background: #2563eb;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

.btn-outline {
  border: 2rpx solid #e2e8f0;
  color: #475569;
  background: #ffffff;
}

.btn-gray {
  background: #f1f5f9;
  color: #475569;
}

/* 空状态 */
.empty-text {
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
  padding: 200rpx 0;
}

/* 工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
